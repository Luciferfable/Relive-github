# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# SMTP host and credentials for sending email notifications.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS=""

# AWS S3 Storage Config (Set real credentials and region)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-north-1"
AWS_S3_BUCKET="relive-storage"

# Firebase Client Configuration (from firebase-applet-config.json)
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_FIRESTORE_DATABASE_ID="(default)"
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""

# Firebase Admin SDK Configuration
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""



